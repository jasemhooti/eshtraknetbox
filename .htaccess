Options -Indexes
DirectoryIndex index.php

# Protect config
<Files "config.php">
  Order allow,deny
  Deny from all
</Files>

# Protect db.php
<Files "db.php">
  Order allow,deny
  Deny from all
</Files>

# Block install after setup
# Uncomment after installation:
# <Files "install.php">
#   Order allow,deny
#   Deny from all
# </Files>
